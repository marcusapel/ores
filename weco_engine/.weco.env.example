# WeCo RDDMS / OSDU Connection Configuration
# Copy this file to .weco.env and fill in your credentials.
# This file is gitignored — never commit secrets.
#
# The Studio GUI reads this on startup for RDDMS connectivity.
# Similar to how ORES uses K8s secrets and Radix environment variables.

# ── Data source mode ──────────────────────────────────────────────────
# "local"  → local RDDMS docker stack (default for development)
# "cloud"  → Equinor OSDU (eqndev / preship / interop)
WECO_MODE=local

# ── Local RDDMS (docker stack on localhost) ───────────────────────────
WECO_RDDMS_URL=http://localhost:3000/api/reservoir-ddms/v2
WECO_DATASPACE=maap/weco
WECO_DATA_PARTITION=dev

# For local: typically no auth needed, leave empty
WECO_TOKEN=

# ── Cloud OSDU (uncomment to switch) ─────────────────────────────────
# WECO_RDDMS_URL=https://equinorswedev.energy.azure.com
# WECO_DATASPACE=maap/weco
# WECO_DATA_PARTITION=dev
# WECO_TOKEN=  (obtain via: az account get-access-token --resource <client-id>)
#
# OAuth2 client credentials (for token refresh):
# WECO_TENANT_ID=3aa4a235-b6e2-48d5-9195-7fcf05b459b0
# WECO_CLIENT_ID=21b442a9-...
# WECO_CLIENT_SECRET=
# WECO_AUTHORITY=https://login.microsoftonline.com/statoil.com

# ── Optional: EPC file (offline, no server needed) ────────────────────
# WECO_EPC_FILE=/path/to/model.epc
