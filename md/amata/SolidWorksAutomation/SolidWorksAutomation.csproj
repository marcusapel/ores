<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>false</UseWPF>
    <UseWindowsForms>false</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <!--
    ── IMPORTANT ──────────────────────────────────────────────
    SolidWorks COM interop DLLs are NOT distributed via NuGet.
    After building, add references to these from your local
    SolidWorks installation (typically C:\Program Files\SOLIDWORKS Corp\SOLIDWORKS):

      • SolidWorks.Interop.sldworks.dll
      • SolidWorks.Interop.swconst.dll
      • SolidWorks.Interop.cosworks.dll   (for Simulation API)

    In Visual Studio:  Right-click References → Add Reference → Browse
    Or use tlbimp on the .tlb files in the SolidWorks install folder.
    ──────────────────────────────────────────────────────────
  -->
</Project>
