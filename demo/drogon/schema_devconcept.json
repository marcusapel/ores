{
  "schemaInfo": {
    "schemaIdentity": {
      "authority": "dev",
      "source": "wks",
      "entityType": "work-product-component--DevelopmentConcept",
      "schemaVersionMajor": 4,
      "schemaVersionMinor": 0,
      "schemaVersionPatch": 0
    },
    "status": "DEVELOPMENT"
  },
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "DevelopmentConcept",
    "description": "Work-product-component describing a proposed field development concept. Strictly the physical concept: what is built, how we drill, how we drain, where we target, how we manage production. Referenced as a sub-element of BusinessDecision via Parameters[]. The BD is the hub for risks, documents, activity, economics, production forecast, schedule - none of that is duplicated here. Where canonical OSDU reference-data types exist (FacilityType, ArtificialLiftType, ReservoirDriveMechanismType) a typed *ID field is provided alongside the human-readable value. Reservoir segments and faults are referenced by OSDU ID - their properties live in master-data--ReservoirSegment records. Optional fields allow sparser early-gate records (DG1 vs DG2+).",
    "x-osdu-governance-authorities": ["dev"],
    "type": "object",
    "required": ["Name"],
    "properties": {

      "Name":        { "type": "string", "description": "Short human-readable name, e.g. 'Drogon DG2 – Development Concept'." },
      "Description": { "type": "string", "description": "Full-text description of the concept and its context." },
      "Summary":     { "type": "string", "description": "Executive summary of the selected development concept." },

      "DecisionGate": {
        "type": "string",
        "enum": ["DG0", "DG1", "DG2", "DG3", "DG4"],
        "description": "Decision gate level (display label)."
      },
      "DecisionLevelID": {
        "type": "string",
        "description": "OSDU ID of reference-data--DecisionLevel record.",
        "x-osdu-relationship": [{ "GroupType": "reference-data", "EntityType": "DecisionLevel" }]
      },

      "FacilityConcept": {
        "type": "object",
        "description": "Facility concept - what is being built / modified.",
        "properties": {
          "FacilityType": {
            "type": "string",
            "enum": ["SubseaTieback", "StandaloneFPSO", "FixedPlatform", "SubseaToShore", "TLP", "Spar", "Semisubmersible", "JackUp", "Onshore"],
            "description": "Primary facility concept type (display label)."
          },
          "FacilityTypeID": {
            "type": "string",
            "description": "OSDU ID of reference-data--FacilityType record.",
            "x-osdu-relationship": [{ "GroupType": "reference-data", "EntityType": "FacilityType" }]
          },
          "HostFacility":       { "type": "string", "description": "Name of host facility for tie-back concepts." },
          "HostFacilityID": {
            "type": "string",
            "description": "OSDU ID of master-data--GenericFacility record for the host.",
            "x-osdu-relationship": [{ "GroupType": "master-data", "EntityType": "GenericFacility" }]
          },
          "HostModifications":  { "type": "string", "description": "Summary of brownfield modifications required on the host." },
          "TemplateCount":      { "type": "integer", "minimum": 0, "description": "Number of subsea templates / manifolds." },
          "SlotsPerTemplate":   { "type": "integer", "minimum": 0, "description": "Well slots per template." },
          "TotalSlots":         { "type": "integer", "minimum": 0, "description": "Total well slots across all templates." },
          "Flowlines": {
            "type": "array",
            "description": "Flowline / riser specifications.",
            "items": {
              "type": "object",
              "properties": {
                "Type": {
                  "type": "string",
                  "enum": ["Production", "GasLift", "WaterInjection", "GasInjection", "Umbilical", "ControlLine"],
                  "description": "Flowline function type."
                },
                "Diameter_in": { "type": "number" },
                "Length_km":   { "type": "number" },
                "Count":       { "type": "integer" },
                "Material":    { "type": "string" }
              }
            }
          },
          "SubseaBoostingPump": { "type": "boolean" },
          "ArtificialLift": {
            "type": "string",
            "enum": ["GasLift", "ESP", "SRP", "PCP", "JetPump", "None"],
            "description": "Primary artificial lift method (display label)."
          },
          "ArtificialLiftTypeID": {
            "type": "string",
            "description": "OSDU ID of reference-data--ArtificialLiftType record.",
            "x-osdu-relationship": [{ "GroupType": "reference-data", "EntityType": "ArtificialLiftType" }]
          },
          "ProcessingCapacity": {
            "type": "object",
            "description": "Key processing capacities on host.",
            "properties": {
              "OilRate_Sm3d":           { "type": "number" },
              "GasRate_MSm3d":          { "type": "number" },
              "WaterTreatment_m3d":     { "type": "number" },
              "GasLiftCapacity_MSm3d":  { "type": "number" },
              "GasExportCapacity_MSm3d":{ "type": "number" }
            }
          },
          "WaterDepth_m":       { "type": "number" },
          "DistanceToHost_km":  { "type": "number" },
          "Provisions":         { "type": "string", "description": "Provisions for future expansion." }
        }
      },

      "WellPlan": {
        "type": "object",
        "description": "Well plan: counts, types, drilling and completion parameters.",
        "properties": {
          "Producers":               { "type": "integer" },
          "Injectors":               { "type": "integer" },
          "ObservationWells":        { "type": "integer" },
          "ContingentWells":         { "type": "integer", "description": "Provisioned but uncommitted." },
          "TotalTargets":            { "type": "integer", "description": "Total drilling targets (may exceed well count for MLT)." },
          "MultilateralWells":       { "type": "integer" },
          "WellTypes": {
            "type": "array",
            "description": "Well type breakdown.",
            "items": {
              "type": "object",
              "properties": {
                "Type":          { "type": "string", "description": "'HorizontalProducer', 'MultilateralProducer', 'WaterInjector', 'Appraisal', etc." },
                "Count":         { "type": "integer" },
                "Names":         { "type": "array", "items": { "type": "string" } },
                "TargetZone":    { "type": "string" },
                "AvgLength_mMD": { "type": "number" }
              }
            }
          },
          "AvgWellDepth_mMD":        { "type": "number" },
          "DrillingDuration_days":    { "type": "number", "description": "Average per-well drilling duration." },
          "CompletionType":          { "type": "string" },
          "SandControl":             { "type": "string" },
          "InflowControl":           { "type": "string", "description": "ICD / AICD / autonomous valve type." },
          "PilotStrategy":           { "type": "string", "description": "Landing pilot, reservoir pilot, etc." }
        }
      },

      "DrainageStrategy": {
        "type": "object",
        "description": "Reservoir drainage and injection strategy.",
        "properties": {
          "PrimaryRecoveryMechanism": {
            "type": "string",
            "enum": ["WaterInjection", "GasInjection", "WAG", "NaturalDepletion", "AquiferSupport", "GasCap"],
            "description": "Primary reservoir drive / recovery mechanism (display label)."
          },
          "ReservoirDriveMechanismTypeID": {
            "type": "string",
            "description": "OSDU ID of reference-data--ReservoirDriveMechanismType record.",
            "x-osdu-relationship": [{ "GroupType": "reference-data", "EntityType": "ReservoirDriveMechanismType" }]
          },
          "InjectionType": {
            "type": "string",
            "enum": ["Water", "Gas", "WAG", "Polymer", "ASP", "LowSalinityWater", "CO2", "Steam", "None"],
            "description": "Injection fluid type."
          },
          "InjectionStrategy":        { "type": "string", "description": "Narrative description of injection approach." },
          "IORStrategy":              { "type": "string", "description": "Improved Oil Recovery strategy and options." },
          "DevelopmentPhases": {
            "type": "array",
            "description": "Phased development stages.",
            "items": {
              "type": "object",
              "properties": {
                "Phase":       { "type": "string" },
                "Description": { "type": "string" },
                "Wells":       { "type": "integer" },
                "StartDate":   { "type": "string" }
              }
            }
          },
          "AquiferSupport":   { "type": "string" },
          "DepletionPlan":    { "type": "string" }
        }
      },

      "ReservoirTarget": {
        "type": "object",
        "description": "Which reservoir interval and structure this concept targets. Segment and fault details live in master-data--ReservoirSegment records.",
        "properties": {
          "FormationName":      { "type": "string", "description": "Lithostratigraphic formation name (display label), e.g. 'Heimdal Fm.'." },
          "FormationID": {
            "type": "string",
            "description": "OSDU ID of a StratigraphicUnitInterpretation record with UnitType=formation. These are lithostratigraphic units from SMDA / NPD strat columns.",
            "x-osdu-relationship": [{ "GroupType": "work-product-component", "EntityType": "StratigraphicUnitInterpretation" }]
          },
          "GroupName":          { "type": "string", "description": "Lithostratigraphic group name (display label), e.g. 'ROGALAND GP.'." },
          "GroupID": {
            "type": "string",
            "description": "OSDU ID of a StratigraphicUnitInterpretation record with UnitType=group.",
            "x-osdu-relationship": [{ "GroupType": "work-product-component", "EntityType": "StratigraphicUnitInterpretation" }]
          },
          "Age":                { "type": "string", "description": "Geological age display label, e.g. 'Palaeocene'." },
          "AgeID": {
            "type": "string",
            "description": "OSDU ID of reference-data--ChronoStratigraphy record for the geological age.",
            "x-osdu-relationship": [{ "GroupType": "reference-data", "EntityType": "ChronoStratigraphy" }]
          },
          "FieldArea":          { "type": "string" },
          "FieldID": {
            "type": "string",
            "description": "OSDU ID of master-data--Field record.",
            "x-osdu-relationship": [{ "GroupType": "master-data", "EntityType": "Field" }]
          },
          "DepthRange_mTVDMSL": {
            "type": "object",
            "properties": { "Min": {"type":"number"}, "Max": {"type":"number"} }
          },
          "Zones":    { "type": "array", "items": { "type": "string" }, "description": "Lithostratigraphic zone/formation/member names targeted (display labels)." },
          "ZoneIDs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "OSDU IDs of StratigraphicUnitInterpretation records for each zone (lithostratigraphic units with UnitType=formation or member).",
            "x-osdu-relationship": [{ "GroupType": "work-product-component", "EntityType": "StratigraphicUnitInterpretation" }]
          },
          "ReservoirSegmentIDs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "OSDU IDs of master-data--ReservoirSegment records targeted. OWC/GOC/fault seal properties are on the segment records themselves.",
            "x-osdu-relationship": [{ "GroupType": "master-data", "EntityType": "ReservoirSegment" }]
          }
        }
      },

      "ProductionTechnology": {
        "type": "object",
        "description": "Production technology and well chemistry considerations.",
        "properties": {
          "SandManagement":       { "type": "string" },
          "ScaleRisk":            { "type": "string" },
          "EmulsionRisk":         { "type": "string" },
          "WaxRisk":              { "type": "string" },
          "CorrosionStrategy":    { "type": "string" },
          "MeteringStrategy":     { "type": "string" },
          "WellAutomation":       { "type": "string" },
          "WaterManagement":      { "type": "string" }
        }
      },

      "ConceptID": { "type": "string", "description": "OSDU ID of a related DevelopmentConcept (e.g. from a prior decision gate for concept lineage)." },

      "ParentObjectID": {
        "type": "string",
        "description": "Reservoir or field master-data ID.",
        "x-osdu-relationship": [{ "GroupType": "master-data", "EntityType": "Reservoir" }]
      },
      "ParentWorkProductID":{ "type": "string" },
      "ancestry": {
        "type": "object",
        "properties": {
          "parents":  { "type": "array", "items": { "type": "string" } },
          "children": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "additionalProperties": true
  }
}
