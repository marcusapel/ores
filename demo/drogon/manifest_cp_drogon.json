      "data": {
        "ProjectName": "Drogon DG2 Geomodelling",
        "Description": "Collaboration workspace for the Drogon DG2 Concept Select phase. Covers seismic interpretation, structural modelling, facies modelling, petrophysical property population, and FMU-driven uncertainty quantification across the Valysar formation (7 reservoir segments, 3 facies types). The project uses RMS for geomodel construction, exports RESQML to RDDMS, and produces volumetric inputs for the DG2 decision.",
        "Purpose": "Build and iterate on the Drogon static reservoir geomodel for DG2 Concept Select. Deliver uncertainty-quantified in-place volumes (P10/P50/P90) per segment and facies, structural framework (faults + horizons), and property models (porosity, NTG, saturation) to support the DG2 investment recommendation.",
        "Namespace": "project-drogon-dg2-geomodelling",
        "LifecycleStatusID": "dev:reference-data--CollaborationProjectLifecycleStatus:Open:",
        "ProjectBeginDate": "2025-12-15T00:00:00Z",
        "ProjectEndDate": "2026-06-30T00:00:00Z",
