                "FAULT_SEAL_SCALING (recovery driver)",
                "KVKH_CHANNEL (sweep efficiency)",
                "RELPERM_INT_WO (water cut / recovery)",
                "VALYSAR_APS_PROB_CHANNEL (facies distribution)"
              ]
            }
