{
  "schemaInfo": {
    "schemaIdentity": {
      "authority": "dev",
      "source": "wks",
      "entityType": "work-product-component--SeismicInterpretationProject",
      "schemaVersionMajor": 1,
      "schemaVersionMinor": 0,
      "schemaVersionPatch": 0
    },
    "status": "DEVELOPMENT",
    "_comment_allOf": "Inherits AbstractWorkProductComponent:1.1.0 → AbstractWPCGroupType:1.2.0 → AbstractCommonResources:1.0.0.  Does NOT inherit AbstractRepresentation or AbstractInterpretation — it is a grouping entity, not a geological object."
  },
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "SeismicInterpretationProject",
    "description": "OSDU catalog record that groups related interpretation products into a coherent session.  Provides a single search entry point for 'all objects from the 2025 Volantis interpretation'.  Links to HorizonInterpretations, SeismicHorizons, StructureMaps, FaultInterpretations, SeismicFaults, VelocityModels, and the RDDMS dataspace.  No existing OSDU schema serves this grouping role — currently achieved via ad-hoc ancestry or naming conventions.",
    "x-osdu-governance-authorities": ["dev"],
    "x-osdu-inherits": ["AbstractWorkProductComponent:1.1.0"],
    "type": "object",
    "required": ["Name"],
    "properties": {
      "Name":        { "type": "string", "description": "Project name, e.g. 'Volantis 2025 Interpretation'." },
      "Description": { "type": "string" },

      "SeismicTraceDataIDs": {
        "type": "array", "items": { "type": "string" },
        "description": "Seismic cubes being interpreted.",
        "x-osdu-relationship": [{ "EntityType": "work-product-component--SeismicTraceData" }]
      },
      "SeismicBinGridID": {
        "type": "string",
        "description": "Primary bin grid for this interpretation session.",
        "x-osdu-relationship": [{ "EntityType": "work-product-component--SeismicBinGrid" }]
      },
      "HorizonInterpretationIDs": {
        "type": "array", "items": { "type": "string" },
        "description": "All horizon interpretations in this project.",
        "x-osdu-relationship": [{ "EntityType": "work-product-component--HorizonInterpretation" }]
      },
      "SeismicHorizonIDs": {
        "type": "array", "items": { "type": "string" },
        "description": "TWT surface picks (SeismicHorizon WPCs).",
        "x-osdu-relationship": [{ "EntityType": "work-product-component--SeismicHorizon" }]
      },
      "StructureMapIDs": {
        "type": "array", "items": { "type": "string" },
        "description": "Depth-converted or standalone structure maps.",
        "x-osdu-relationship": [{ "EntityType": "work-product-component--StructureMap" }]
      },
      "FaultInterpretationIDs": {
        "type": "array", "items": { "type": "string" },
        "description": "Fault interpretations.",
        "x-osdu-relationship": [{ "EntityType": "work-product-component--FaultInterpretation" }]
      },
      "SeismicFaultIDs": {
        "type": "array", "items": { "type": "string" },
        "description": "Fault representations (sticks, surfaces).",
        "x-osdu-relationship": [{ "EntityType": "work-product-component--SeismicFault" }]
      },
      "VelocityModelingID": {
        "type": "string",
        "description": "Velocity model used for depth conversion.",
        "x-osdu-relationship": [{ "EntityType": "work-product-component--VelocityModeling" }]
      },

      "InterpreterName":    { "type": "string", "description": "Person/team who performed the interpretation." },
      "InterpretationDate": { "type": "string", "format": "date-time" },
      "SoftwareUsed":       { "type": "string", "description": "Application name + version." },

      "ResqmlDataspaceID": {
        "type": "string",
        "description": "Link to the dataset--ETPDataspace record for RDDMS access to the underlying RESQML objects.",
        "x-osdu-relationship": [{ "EntityType": "dataset--ETPDataspace" }]
      }
    },
    "additionalProperties": true
  }
}
