# Docker ignore — exclude build artifacts, docs, IDE config
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
dist/
build/
.python_build/
.pytest_cache/
.tox/
*.so
*.o
*.a
out.txt

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Documentation source (not needed at runtime)
doc_src/
doc/doc/

# Misc
*.bat
*.sh
*.log
bin/
tmp/
